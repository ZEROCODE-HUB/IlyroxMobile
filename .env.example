# Copia este archivo a `.env` y rellena los valores.
# `.env` está en .gitignore: nunca se versiona.
#
# En EAS estas mismas variables viven como environment variables del proyecto
# (`eas env:list --environment production`), y cada perfil de build las recibe
# por su campo `environment` en eas.json.
#
# Todo lo que empieza por EXPO_PUBLIC_ se incrusta en el bundle y, por tanto,
# es visible para cualquiera que abra el APK/IPA. No pongas aquí secretos
# reales (service_role, claves privadas): la protección de estas claves son las
# restricciones del proveedor (bundle ID / SHA-1 en Google Cloud) y RLS en
# Supabase.

EXPO_PUBLIC_ONESIGNAL_APP_ID=

# Restringidas por bundle ID / SHA-1 en Google Cloud Console
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_API_KEY=
EXPO_PUBLIC_GOOGLE_MAPS_IOS_API_KEY=

# Proyecto principal — la anon key es pública por diseño; protege con RLS
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Proyecto de datos geográficos
EXPO_PUBLIC_SUPABASE_GEO_URL=
EXPO_PUBLIC_SUPABASE_GEO_ANON_KEY=

# Nota: el .env local aún define EXPO_PUBLIC_R2_ACCESS_KEY y
# EXPO_PUBLIC_R2_SECRET_ACCESS_KEY. Ningún archivo de src/ las usa (las subidas
# van contra el servicio externo de imágenes), así que hoy no entran en el
# bundle. No las reintroduzcas con el prefijo EXPO_PUBLIC_: una secret key de R2
# incrustada en el binario permitiría escribir y borrar en el bucket.
