{
  "expo": {
    "name": "i360",
    "slug": "i360",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/Icon-size.png",
    "userInterfaceStyle": "light",
    "scheme": "i360realestate",
    "splash": {
      "image": "./src/assets/Icon-size.png",
      "resizeMode": "cover",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.i360.realestateapp",
      "infoPlist": {
        "UIViewControllerBasedStatusBarAppearance": false,
        "UIStatusBarStyle": "UIStatusBarStyleLightContent",
        "UIBackgroundModes": ["remote-notification"]
      },
      "entitlements": {
        "aps-environment": "development",
        "com.apple.security.application-groups": [
          "group.com.i360.realestateapp.onesignal"
        ]
      },
      "config": {
        "googleMapsApiKey": "AIzaSyCMns7F3TjXiJ4oswwws0USAgum-GcwM9A"
      },
      "associatedDomains": ["applinks:i360.app", "applinks:*.i360.app"]
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "largeHeap": true,
      "statusBar": {
        "barStyle": "light-content",
        "backgroundColor": "#FFFFFF",
        "translucent": false,
        "hidden": false
      },
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/Icon-size.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.i360.realestateapp",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyB2SD7BpH4ms3h3N4FiXcTv1CZdlElhRGg"
        }
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "i360.app",
              "pathPrefix": "/feed"
            },
            {
              "scheme": "i360realestate"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./src/assets/Icon-size.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./src/assets/Icon-size.png",
          "dark": {
            "image": "./src/assets/Icon-size.png",
            "backgroundColor": "#FFFFFF"
          },
          "imageWidth": 200
        }
      ],
      [
        "onesignal-expo-plugin",
        {
          "mode": "development"
        }
      ],
      "expo-video",
      "@react-native-community/datetimepicker",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "OneSignalNotificationServiceExtension",
                  "bundleIdentifier": "com.i360.realestateapp.OneSignalNotificationServiceExtension",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.i360.realestateapp.onesignal"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "a8b8b8c1-fc02-4f09-ae8e-9d929f564dd5"
      }
    }
  }
}
