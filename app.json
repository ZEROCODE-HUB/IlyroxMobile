{
  "expo": {
    "name": "i360",
    "slug": "i360",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "i360realestate",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#06D5B4"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.i360.realestateapp",
      "infoPlist": {
        "UIViewControllerBasedStatusBarAppearance": false,
        "UIStatusBarStyle": "UIStatusBarStyleLightContent",
        "UIBackgroundModes": [
          "remote-notification"
        ]
      },
      "entitlements": {
        "aps-environment": "development",
        "com.apple.security.application-groups": [
          "group.com.i360.realestateapp.onesignal"
        ]
      },
      "config": {
        "googleMapsApiKey": "AIzaSyCMns7F3TjXiJ4oswwws0USAgum-GcwM9A"
      },
      "associatedDomains": [
        "applinks:i360.app",
        "applinks:*.i360.app"
      ]
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "largeHeap": true,
      "statusBar": {
        "barStyle": "light-content",
        "backgroundColor": "#06D5B4",
        "translucent": false,
        "hidden": false
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#06D5B4"
      },
      "package": "com.i360.realestateapp",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyB2SD7BpH4ms3h3N4FiXcTv1CZdlElhRGg"
        }
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "i360.app",
              "pathPrefix": "/feed"
            },
            {
              "scheme": "i360realestate"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "onesignal-expo-plugin",
        {
          "mode": "development"
        }
      ],
      "expo-video",
      "@react-native-community/datetimepicker",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "OneSignalNotificationServiceExtension",
                  "bundleIdentifier": "com.i360.realestateapp.OneSignalNotificationServiceExtension",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.i360.realestateapp.onesignal"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "a8b8b8c1-fc02-4f09-ae8e-9d929f564dd5"
      }
    }
  }
}
